  m_Name: GameManager
  m_TagString: Untagged
  m_Icon: {fileID: 0}
  m_NavMeshLayer: 0
  m_StaticEditorFlags: 0
  m_IsActive: 1
--- !u!114 &1525430225
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1525430224}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6ee5caa2a1f4bc347ba22f2a6e557951, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  nameText: {fileID: 166285906}
  dialogueText: {fileID: 200443317}
  choicePanel: {fileID: 290156004}
  characterImage: {fileID: 255858802}
  backgroundImage: {fileID: 901164830}
  effects: {fileID: 1525430230}
  commonLines:
  - speakerName: Clark
    sentence: ' "Thank you kindly!" [smile eyes closed sprite] '
    characterSprite: {fileID: 513670334897225390, guid: fc7480eee692ff541868f724d5801419, type: 3}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: (The gruff manager taps the box before him, glancing up at the detective
      with a small chuckle.)
    characterSprite: {fileID: 2949794678921438717, guid: 2d971393986b7514188d1ea104fdd231, type: 3}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: Clark
    sentence: '"I''ve known you for years and I never expected you''d be the type
      to buy an Omunus, Inspector." [brow raised sprite]'
    characterSprite: {fileID: -7420667688293835269, guid: 6599594b1b9f9504497e22af5342fd5c, type: 3}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    clearShade: 0
  - speakerName: Clark
    sentence: '"In fact, might be the first time I''ve seen you come in here at all.
      ''Least for yourself." [smile eyes closed sprite]'
    characterSprite: {fileID: 513670334897225390, guid: fc7480eee692ff541868f724d5801419, type: 3}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: ' (She sure hates to admit it, but Clark is right. Too right.) [his
      sprite in bg changes to his plain smile sprite]'
    characterSprite: {fileID: 4744044922728678267, guid: 73a815d654837674496ed70c59aa1ca7, type: 3}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: (This is very out of character for Detective Inspector Russo. She's
      not a gamer, so that's not it. She definitely isn't into new technology ---
      that's for sure. )
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: ' (So why? Why bother? Not like she gets paid much anyway.) '
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: (Well --- whatever it is, it's very unlike Laura Russo to buy an expensive
      virtual reality headset.)
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: Laura
    sentence: '"There''s lots of things you don''t know about me, Clark." [here,
      lauras sprite appears for the first time! mc reveal wow]'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: '(The man laughs, raising a brow.) [eyes closed smile sprite]'
    characterSprite: {fileID: 2949794678921438717, guid: 2d971393986b7514188d1ea104fdd231, type: 3}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: Clark
    sentence: '"Right, right. Detectives and their mysteries, ay?" [brow raised sprite]

'
    characterSprite: {fileID: -7420667688293835269, guid: 6599594b1b9f9504497e22af5342fd5c, type: 3}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: Laura
    sentence: '"You know it." [dry smile sprite]



'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: ' (Laura glances down at her receipt, wincing internally... 500 Euros...)
      [hide her sprite]



'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: ' (She grabs it, forcing a soft smile up at Clark before heading out
      of the store.)'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: Clark
    sentence: '  "Inspector! Ya don''t want a bag?" [yell sprite]'
    characterSprite: {fileID: 6564129248582252230, guid: e62cf96b3683bb24aa3c1491c30d51ee, type: 3}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: '"Nope! Thank you, Clark!" [fade out]'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 2447145390109583473, guid: c7320e213f8c23341b766b31e861187c, type: 3}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: '(...) [black screen]'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: ' (Laura steps out past the metal detectors, glancing around the packed
      parking lot.) [fade back in, parking lot bg1, background ambience of people]'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: (It's not a large area, that's for sure. Despite that, it shocks Laura
      --- for how small of a town //Regno Azzurro// is, this store's popular.)
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: (It's a bit jarring. She usually doesn't bother looking at this place
      twice, and yet... it's probably one of the town's hottest spots.)
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: Laura
    sentence: '"..." [show serious sprite]'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: Laura
    sentence: '"..." [show squinting, angrier sprite]'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: Laura
    sentence: '"Where the hell did I even park?" [same sprite, mouth open alternative]'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: '"..." [show squinting, angrier sprite]'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: (Laura looks to the left, narrowing her tired eyes.)
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: (Her car shouldn't be hard to miss --- at least for her. For anyone
      else, definitely. It's just a beat-up Sedan, like many others...)
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: '(Laura shifts the Omunus box to one arm, biting her tongue as she
      reaches for her pocket.) '
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: (...)
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: Laura
    sentence: ' "Damn it..." [smaller text to signify she''s muttering under her
      breath]'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: (After some brief struggle, she manages to grab her keys. She readjusts
      the box --- more comfortably now --- and presses down on the panic button.)
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: '(BEEP!) [loud font = loud]'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: 
    sentence: '(Oh, it''s to the --- [if you can cut off this line, as if actually
      cut off.]'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: Neil
    sentence: '"Detective!"'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: Laura
    sentence: '"Oh, for god''s sake..." " [smaller text to signify she''s muttering
      under her breath]'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: Laura
    sentence: ' "Hey, Neil... Been a while."'
    characterSprite: {fileID: 0}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: Neil
    sentence: ' "Hey, Neil... Been a while."'
    characterSprite: {fileID: 4335161177639129098, guid: 050d235147d8b25478ffb549a7b05fde, type: 3}
    hideCharacter: 0
    background: {fileID: 0}
    playEffect: 0
    shadeOverlay: {fileID: 0}
    clearShade: 0
  - speakerName: Laura
    sentence: '"Uh, Omunus, but yeah ---" [if you can cut off this line, as if shes
      actually cut off.]'
    characterSprite: {fileID: 0}
    hideCharacter: 0
